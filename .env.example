# =============================================
# Highrise Bot Konfiguration
# Kopiere diese Datei zu .env und passe die Werte an!
# =============================================

# Bot-Zugangsdaten (von create.highrise.game)
BOT_TOKEN=DEIN_BOT_TOKEN_HIER
BOT_ID=DEINE_BOT_ID
ROOM_ID=DEINE_ROOM_ID

# Owner
OWNER_ID=DEINE_OWNER_ID
OWNER_USERNAME=DEIN_USERNAME

# Gold-Einstellungen
GOLD_ENABLED=true
GOLD_AMOLD=1
GOLD_INTERVAL_MINUTES=60
GOLD_INTERVAL_MODE=fixed

# Musik
MUSIC_ENABLED=true
MUSIC_GOLD_COST=10
AUTO_PLAYLIST_ENABLED=true
AUTO_PLAYLIST_URL=https://youtube.com/playlist?list=DEINE_PLAYLIST_ID

# Icecast
ICECAST_SOURCE_PASS=DEIN_ICECAST_PASSWORT

# Web Panel
PANEL_PASSWORD=DEIN_PANEL_PASSWORT
