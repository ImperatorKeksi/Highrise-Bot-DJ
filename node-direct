#!/bin/bash
args=()
for arg in "$@"; do
    if [[ "$arg" == --permission=* ]] || [[ "$arg" == "--permission" ]]; then
        continue
    fi
    args+=("$arg")
done
# Stdin in Datei speichern und dann an node.real weitergeben
if [[ "${args[@]}" == *"-"* ]]; then
    stdin_data=$(cat)
    echo "$(date) STDIN: ${stdin_data:0:100}" >> /tmp/node-debug.log
    echo "$stdin_data" | exec /usr/bin/node.real "${args[@]}"
else
    exec /usr/bin/node.real "${args[@]}"
fi
